{
  "schema": "simple-standard-item-catalog-v1",
  "intendedUse": "Autofill source data for Phase 7 Standard Item Autofill. Entries are catalog templates, not complete InventoryRecord instances; Codex should add id, entityId, location, sortOrder, timestamps, and any UI defaults at creation time.",
  "modelCompatibility": {
    "checkedAgainst": "arronkau/simple main src/model/types.ts as of 2026-06-04",
    "recordFieldsUsed": [
      "name",
      "recordType",
      "quantity",
      "burden",
      "handsRequired",
      "description",
      "container",
      "uses",
      "light",
      "weapon",
      "armor"
    ],
    "catalogMetadataFields": [
      "slug",
      "source",
      "gpValue",
      "aliases",
      "catalogNotes"
    ],
    "notes": [
      "gpValue is included as catalog metadata for future price/shop use. Current InventoryRecord types only define gpValue under treasure; do not blindly persist gpValue onto non-treasure InventoryRecord objects unless the app model is extended."
    ]
  },
  "normalizationRules": {
    "weaponsAndArmor": "Use only house-rules armor and weapon entries. Do not import OSE weapon or armor rows. Torch is not a weapon entry.",
    "nonWeaponsAndNonArmor": "Use OSE standard and expanded equipment sources.",
    "burdenDefaults": "0 slots for tiny items; 1 slot for ordinary carried items; 2 slots for substantially large/heavy items; 3 slots for very bulky items; 5 slots for large iron box per user instruction.",
    "containerCapacity": "Coin capacity converted at 50 coins = 1 slot; no fractional capacities. Liquid capacities are recorded only in descriptions.",
    "stackables": "Purchase bundles are modeled as stackable entries with default quantity equal to bundle size and itemsPerSlot equal to bundle size.",
    "weaponDamage": "Omitted because house rules make weapon damage class-based.",
    "weaponRange": "Missile ranges are parsed into weapon.range without the word Missile.",
    "omissions": [
      "Belt pouch omitted because app handles coin purse/display separately.",
      "Treasure placeholders omitted per user instruction.",
      "House-rules ammunition rows omitted; ammunition comes from non-weapon equipment sources when present."
    ]
  },
