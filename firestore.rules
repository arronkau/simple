rules_version = '2';

// TODO(firestore-tests): Add Firestore emulator-based security rule tests before 0.1 release.
// Required coverage:
//   - unauthenticated user cannot read party
//   - unauthenticated user cannot write party
//   - non-member cannot read party
//   - non-member cannot write party
//   - player can perform allowed entity/inventory writes
//   - player cannot edit party settings (displayName, gmUid, members)
//   - player cannot edit members map
//   - GM can perform administrative writes
//   - subcollection path cannot be read or written by anyone
// Note: deep per-item validation of identification.secretName/secretDescription within the
// inventoryRecords array is not feasible in Firestore rules. That protection is enforced
// at the model/store layer in src/store/useAppStore.ts.

service cloud.firestore {
  match /databases/{database}/documents {
    match /parties/{partyId} {
      // Read: must be authenticated and a party member
      allow read: if isAuthenticatedMember();

      // Create: must be authenticated and creating themselves as GM
      allow create: if request.auth != null
                    && request.resource.data.party.gmUid == request.auth.uid
                    && request.auth.uid in request.resource.data.party.members;

      // Update: must be a member AND either be the GM or only touching player-allowed fields
      allow update: if isAuthenticatedMember()
                    && (isGm() || isAllowedPlayerUpdate());

      // Delete: only the GM may delete the party document
      allow delete: if isGm();
    }

    // Deny all access to any subcollection paths under parties.
    // This app uses single documents only; this rule is defensive.
    match /parties/{partyId}/{document=**} {
      allow read, write: if false;
    }

    // --- Helper functions ---

    function isAuthenticatedMember() {
      return request.auth != null
        && resource.data.party.members != null
        && request.auth.uid in resource.data.party.members;
    }

    function isGm() {
      return request.auth != null
        && resource.data.party.gmUid == request.auth.uid;
    }

    // Players may write the document only if they have not changed any GM-only fields.
    // GM-only party-level fields: party.displayName, party.gmUid, party.members
    // Note: nested inventoryRecords secretName/secretDescription cannot be validated
    // per-item in rules — enforced in the app layer instead.
    function isAllowedPlayerUpdate() {
      return request.auth != null
        // Must remain a member
        && request.auth.uid in resource.data.party.members
        // May not change the GM
        && request.resource.data.party.gmUid == resource.data.party.gmUid
        // May not change the members map
        && request.resource.data.party.members == resource.data.party.members
        // May not rename the party
        && request.resource.data.party.displayName == resource.data.party.displayName;
    }
  }
}
